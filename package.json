{
  "name": "@the-fbf/sunsetter-aqm",
  "version": "1.6.2",
  "description": "SunSetter AQM+ - Database to Convex Migration Tool with beautiful TUI. AQM = Actions, Queries, Mutations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "mcp-configs",
    "codegen.config.example.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./utils/connection-validator": {
      "types": "./dist/utils/connection-validator.d.ts",
      "import": "./dist/utils/connection-validator.js"
    },
    "./utils/fuzzy-match": {
      "types": "./dist/utils/fuzzy-match.d.ts",
      "import": "./dist/utils/fuzzy-match.js"
    }
  },
  "bin": {
    "sunsetter-aqm": "dist/index.js",
    "sunsetter": "dist/index.js",
    "aqm": "dist/index.js",
    "sunsetter-mcp": "dist/mcp/server.js"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heyoub/SunSetter_AQM.git"
  },
  "homepage": "https://sunsetter-aqm.heyoub.dev",
  "bugs": {
    "url": "https://github.com/heyoub/SunSetter_AQM/issues"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "tui": "node dist/tui/app.js",
    "mcp": "node dist/mcp/server.js",
    "dev": "nodemon --exec ts-node --esm src/index.ts",
    "dev:tui": "ts-node --esm src/tui/app.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepack": "npm run build",
    "prepare": "[ -d .git ] && husky install || true"
  },
  "mcpServers": {
    "sunsetter-aqm": {
      "command": "node",
      "args": [
        "dist/mcp/server.js"
      ],
      "description": "SunSetter AQM+ - Database to Convex migration tool with schema introspection, code generation, and migration capabilities"
    }
  },
  "keywords": [
    "sunsetter",
    "aqm",
    "convex",
    "postgresql",
    "mysql",
    "sqlite",
    "mssql",
    "migration",
    "database",
    "code-generation",
    "typescript",
    "schema",
    "cli",
    "tui",
    "terminal",
    "esm",
    "sql",
    "introspection",
    "validators",
    "queries",
    "mutations",
    "actions",
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "claude-desktop",
    "ai-tools"
  ],
  "author": "Heyoub (https://heyoub.dev)",
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "ascii-art-font": "^1.0.2",
    "better-sqlite3": "^12.5.0",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "commander": "^11.1.0",
    "convex": "^1.8.0",
    "dotenv": "^16.3.1",
    "figlet": "^1.9.4",
    "gradient-string": "^3.0.0",
    "ink": "^6.6.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^3.0.0",
    "ink-progress-bar": "^3.0.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "inquirer": "^9.2.12",
    "mssql": "^12.2.0",
    "mysql2": "^3.16.0",
    "open": "^11.0.0",
    "ora": "^7.0.1",
    "pg": "^8.11.3",
    "terminal-kit": "^3.1.2",
    "tslib": "^2.6.2",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/benchmark": "^2.1.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/blessed": "^0.1.27",
    "@types/figlet": "^1.7.0",
    "@types/cli-progress": "^3.11.5",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^29.5.8",
    "@types/mssql": "^9.1.8",
    "@types/node": "^20.10.5",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "benchmark": "^2.1.4",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "fast-check": "^4.5.2",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
